<%- js('/js/jquery-2.0.3.min') %>
<%- js('/js/jquery.justifiedGallery.min') %>
<%- js('/js/lazyload.min') %>
<script>
  (function () {
    var hasVisitCounter = document.getElementById('busuanzi_value_site_pv') ||
      document.getElementById('busuanzi_value_site_uv') ||
      document.getElementById('busuanzi_value_page_pv');
    if (!hasVisitCounter) return;

    function loadVisitCounter() {
      var script = document.createElement('script');
      script.src = '<%- url_for('/js/busuanzi-2.3.pure.min.js') %>';
      script.defer = true;
      document.body.appendChild(script);
    }

    if (window.requestIdleCallback) {
      window.requestIdleCallback(loadVisitCounter, { timeout: 2000 });
    } else {
      window.addEventListener('load', function () {
        window.setTimeout(loadVisitCounter, 1000);
      });
    }
  }());
</script>
<% if (theme.fancybox){ %>
  <%- js('fancybox/jquery.fancybox.min') %>
<% } %>

<% if (theme.toc && is_post()){ %>
  <%- js('/js/tocbot.min') %>
  <script>
    // Tocbot_v4.7.0  http://tscanlin.github.io/tocbot/
    tocbot.init({
      tocSelector: '.tocbot',
      contentSelector: '.article-entry',
      headingSelector: 'h1, h2, h3, h4, h5, h6',
      hasInnerContainers: true,
      scrollSmooth: true,
      positionFixedSelector: '.tocbot',
      positionFixedClass: 'is-position-fixed',
      fixedSidebarOffset: 'auto',
    });
  </script>
<% } %>

